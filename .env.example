# ============================================================
# ClawBot / OpenClaw .env template
# Copy to .env and fill in real values. .env is gitignored.
# Format: KEY=value, no spaces around =, no quotes unless needed.
# ============================================================

# ----- BLOFIN (secondary exchange) -----
BLOFIN_API_KEY=
BLOFIN_SECRET=
# Risk % of portfolio per trade — 5.0 = $5 on a $100 portfolio (min order ~$5)
TRADE_RISK_PCT=5.0


# ----- TELEGRAM (bot, watchdog, alerts) -----
# from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=
# your numeric chat id (DM your bot, then visit api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=
# authorized chat id(s); comma-separated for multiple
ALLOWED_CHAT_ID=


# ----- AUTOTRADE (cloud persistence — survives container restarts) -----
# Set these so auto-trade survives restarts without needing /autotrade on each time
AUTOTRADE_ENABLED=false
# same value as ALLOWED_CHAT_ID
AUTOTRADE_CHAT_ID=
# UTC time for the daily scan
AUTOTRADE_TIME=08:00
# 1h | 4h | 1d
AUTOTRADE_TIMEFRAME=4h


# ----- AI MODELS (Claude + Ollama + OpenRouter) -----
# console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=
# fall back to Claude API when Ollama is down
USE_CLAUDE_API=true
# local LLM model name
OLLAMA_MODEL=qwen2.5:14b
# OpenRouter cloud middle-layer (cheap open-source LLMs as Ollama fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# optional response cap
MAX_TOKENS_PER_RESPONSE=500
# optional brain routing knob — word count above which a prompt is routed to Claude
COMPLEXITY_THRESHOLD=50


# ----- CRYPTO TRADING (Crypto.com + risk) -----
# crypto.com/exchange -> Settings -> API Keys (read+trade only; NO withdraw)
CRYPTOCOM_API_KEY=
CRYPTOCOM_SECRET=
# circuit-breaker baseline ($)
STARTING_BALANCE_USD=96.00
# halt threshold (0.20 = 20%)
MAX_DRAWDOWN_PCT=0.20


# ----- CONTENT POSTING (Instagram + TikTok) -----
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# developers.tiktok.com
TIKTOK_ACCESS_TOKEN=

# ----- MEDIA / FILES -----
# tiny / base / small / medium / large
WHISPER_MODEL=base
# gdrive watch dir path (optional)
GDRIVE_WATCH_FOLDER=
# background music folder path (optional)
MUSIC_FOLDER=


# ----- HAULYEAH (trash_hauling_bot) -----
# ANTHROPIC_API_KEY above is shared (not duplicated here).
# separate BotFather token (NOT TELEGRAM_BOT_TOKEN)
TRASH_BOT_TOKEN=
# authorized chat id(s), comma-separated
TRASH_BOT_CHAT_IDS=
# founder/team chat ids, comma-separated
TRASH_BOT_TEAM_CHAT_IDS=
# path to service-account JSON
GOOGLE_CREDENTIALS_FILE=data/google_credentials.json
# Google Sheet for lead tracking
GOOGLE_SHEET_ID=
# Google Calendar id for bookings
GOOGLE_CALENDAR_ID=primary
# Facebook Marketplace search city/region
FB_SEARCH_LOCATION=
FB_SEARCH_RADIUS_MILES=50
FB_SEARCH_KEYWORDS=trash hauling,junk removal,cleanout,debris removal,haul away
# Playwright user-data dir for FB session
FB_PROFILE_DIR=data/fb_profile
SCRAPER_INTERVAL_MINUTES=30
CALENDAR_SYNC_INTERVAL_MINUTES=5
LEAD_STALE_DAYS=7
# true for keyless smoke testing
DRY_RUN=false
# HaulYeah runtime data dir
DATA_DIR=data
# HaulYeah audit log path
AUDIT_LOG_FILE=data/audit.log


# ----- JARVIS UI GATEWAY (WebSocket bridge at ws://127.0.0.1:18789) -----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable the JARVIS Gateway on startup
GATEWAY_TOKEN=
