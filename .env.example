# ── Crypto.com Exchange (primary trading venue) ───────────────────────────────
CRYPTOCOM_API_KEY=
CRYPTOCOM_SECRET=
# Set to false to go live (default true = demo/paper mode)
DEMO_MODE=true

# ── Google Sheets reporting ───────────────────────────────────────────────────
# Sheet already live — ID is fixed:
GOOGLE_SHEET_ID=1hH7HTk-klm1828Jzalob5yrdsXXWGajGb0cPCofYkUs
#
# Auth option A — full service account JSON as one line (Railway env var):
GOOGLE_CREDS_JSON=
#
# Auth option B — path to credentials JSON file (local dev):
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# ── BloFin (legacy — no longer primary) ──────────────────────────────────────
BLOFIN_API_KEY=
BLOFIN_SECRET=
BLOFIN_PASSPHRASE=

# ── Ollama local model pool ───────────────────────────────────────────────────
# Default fallback model (must be installed via: ollama pull qwen2.5:14b)
OLLAMA_MODEL=qwen2.5:14b
# Task-specific routing — override per task if you want to pin a model
# OLLAMA_MODEL_COMPRESSION=qwen3       # trade lesson compression
# OLLAMA_MODEL_REASONING=qwen3         # operational reasoning
# OLLAMA_MODEL_CODE=deepseek-coder     # code tasks
# OLLAMA_MODEL_UTILITY=gemma3          # lightweight utilities

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated list of authorized chat IDs (whitelist)
ALLOWED_CHAT_ID=

# Content pipeline
GDRIVE_WATCH_FOLDER=
MUSIC_FOLDER=content/music
WHISPER_MODEL=base

# TikTok Content Posting API
# Get from: developers.tiktok.com → your app → Content Posting API
TIKTOK_ACCESS_TOKEN=

# Instagram / Meta Graph API
# Get from: developers.facebook.com → your app → Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Hybrid AI Brain (Claude API)
# Get from: console.anthropic.com → API Keys
# Leave blank to use Ollama only (fully free/local)
ANTHROPIC_API_KEY=
USE_CLAUDE_API=true
MAX_TOKENS_PER_RESPONSE=500
# Word count above which a prompt is routed to Claude (default 50)
COMPLEXITY_THRESHOLD=50
