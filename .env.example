CRYPTOCOM_API_KEY=
CRYPTOCOM_SECRET=
BLOFIN_API_KEY=
BLOFIN_SECRET=
OLLAMA_MODEL=qwen2.5:14b

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Your personal Telegram chat ID — get it from @userinfobot
ALLOWED_CHAT_ID=

# Auto-trade cloud config (used on Railway/cloud where data/ is ephemeral)
# Set these so auto-trade survives container restarts without needing /autotrade on each time
AUTOTRADE_ENABLED=false
AUTOTRADE_CHAT_ID=          # same value as ALLOWED_CHAT_ID
AUTOTRADE_TIME=08:00        # UTC time for daily scan
AUTOTRADE_TIMEFRAME=4h      # 1h | 4h | 1d

# Content pipeline
GDRIVE_WATCH_FOLDER=
MUSIC_FOLDER=content/music
WHISPER_MODEL=base

# TikTok Content Posting API
# Get from: developers.tiktok.com → your app → Content Posting API
TIKTOK_ACCESS_TOKEN=

# Instagram / Meta Graph API
# Get from: developers.facebook.com → your app → Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Hybrid AI Brain (Claude API)
# Get from: console.anthropic.com → API Keys
# Leave blank to use Ollama only (fully free/local)
ANTHROPIC_API_KEY=
USE_CLAUDE_API=true
MAX_TOKENS_PER_RESPONSE=500
# Word count above which a prompt is routed to Claude (default 50)
COMPLEXITY_THRESHOLD=50
