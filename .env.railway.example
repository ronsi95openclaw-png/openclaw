# ── Required for OpenRouter (replaces local Ollama in cloud) ──────────────────
OPENROUTER_API_KEY=sk-or-v1-...           # get from openrouter.ai
OPENROUTER_SITE_URL=https://openclaw.app  # your site (shown on OR dashboard)
OPENROUTER_SITE_NAME=OpenClaw

# ── Optional: override which model QUIN uses via OpenRouter ──────────────────
# Default: qwen/qwen-2.5-14b-instruct
# Cheaper option: qwen/qwen-2.5-7b-instruct
# Best reasoning: qwen/qwen3-14b
QUIN_OPENROUTER_MODEL=qwen/qwen-2.5-14b-instruct

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8647354078:AAEbBwS6pqJ2_H6tXVWFXzj3mLcEO6s6ptk
TELEGRAM_CHAT_ID=6082698835

# ── Trading (demo only in cloud) ──────────────────────────────────────────────
DEMO_MODE=true
CRYPTOCOM_API_KEY=                        # leave blank for demo
CRYPTOCOM_SECRET=                         # leave blank for demo

# ── Anthropic (for nightly Claude analysis) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets (optional) ──────────────────────────────────────────────────
# Don't set GOOGLE_SHEETS_CREDENTIALS_FILE in Railway — use service account JSON
# stored as an env var instead (see Railway docs on secret files)
GOOGLE_SHEET_ID=

# ── Dashboard ─────────────────────────────────────────────────────────────────
PORT=8000

# ── Runtime feature flags ─────────────────────────────────────────────────────
RUFLO_ENABLED=false           # Node.js subprocess — disable on Railway (no Node runtime)

# ── Telegram webhook security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=      # set this, then re-register webhook with secret_token=
