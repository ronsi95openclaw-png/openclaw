# ============================================================
# Trash Hauling Lead Gen Bot — Environment Configuration
# This bot is SEPARATE from ClawBot. Use a different BotFather token.
# ============================================================

# ---- Telegram (dedicated trash hauling bot) ----------------
TRASH_BOT_TOKEN=            # Get from @BotFather — must be a NEW bot, not ClawBot
TRASH_BOT_CHAT_IDS=         # Comma-separated authorized chat IDs, e.g. 123456789,987654321
TRASH_BOT_TEAM_CHAT_IDS=    # Chat IDs that receive job alerts (can overlap with above)

# ---- Google (Service Account) ------------------------------
# 1. Create a project at console.cloud.google.com
# 2. Enable Sheets API + Calendar API
# 3. Create a Service Account, download JSON key → save as data/google_credentials.json
# 4. Share your Google Sheet and Calendar with the service account email
GOOGLE_CREDENTIALS_FILE=data/google_credentials.json
GOOGLE_SHEET_ID=            # From the sheet URL: /spreadsheets/d/<SHEET_ID>/edit
GOOGLE_CALENDAR_ID=primary  # Use 'primary' or a specific calendar ID

# ---- Claude API (outreach message generation) --------------
# Optional — falls back to a built-in template if not provided
ANTHROPIC_API_KEY=

# ---- Facebook Marketplace Scraping -------------------------
FB_SEARCH_LOCATION=Houston, TX
FB_SEARCH_RADIUS_MILES=50
FB_SEARCH_KEYWORDS=trash hauling,junk removal,cleanout,debris removal,haul away
# On first run: python -m trash_hauling_bot.agents.scraper --login
# This opens a real browser window to log into Facebook once; session is saved.
FB_PROFILE_DIR=data/fb_profile

# ---- Scheduler ---------------------------------------------
SCRAPER_INTERVAL_MINUTES=30    # FB scan frequency
CALENDAR_SYNC_INTERVAL_MINUTES=5

# ---- Paths -------------------------------------------------
DATA_DIR=data
AUDIT_LOG_FILE=data/audit.log
