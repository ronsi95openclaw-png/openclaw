{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "OpenClaw Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "OpenClaw trading bot — production health dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Capital State",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_capital_state",
          "legendFormat": "State"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SAFE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DEFENSIVE", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "CRITICAL", "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "HALT", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_open_positions_total", "legendFormat": "Positions" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total PnL (USD)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_total_pnl_usd", "legendFormat": "PnL" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reconciliation Status",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_reconciliation_passed", "legendFormat": "Passed" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASSED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Drift Events",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_drift_events_active", "legendFormat": "Active Drifts" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "WS Health Score",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_ws_health_score", "legendFormat": "WS Health" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "PnL Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_total_pnl_usd", "legendFormat": "Total PnL" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Scan Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(openclaw_scan_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(openclaw_scan_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Reconciliation Results",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(openclaw_reconciliation_runs_total[5m])", "legendFormat": "Runs/min" },
        { "expr": "rate(openclaw_reconciliation_failures_total[5m])", "legendFormat": "Failures/min" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "EventStore Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(openclaw_event_store_appends_total[1m])", "legendFormat": "Events/sec" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage (MB)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS MB" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Active Threads",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_thread_count", "legendFormat": "Threads" }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Recent Critical Incidents",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_critical_incidents_total", "legendFormat": "Incidents" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["openclaw", "trading", "crypto"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "UTC",
  "title": "OpenClaw Trading Bot",
  "uid": "openclaw-main",
  "version": 1
}
