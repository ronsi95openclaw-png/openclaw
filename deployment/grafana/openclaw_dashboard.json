{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "OpenClaw Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "OpenClaw trading bot — production health dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Capital State",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_capital_state",
          "legendFormat": "State"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SAFE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DEFENSIVE", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "CRITICAL", "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "HALT", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_open_positions_total", "legendFormat": "Positions" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total PnL (USD)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_total_pnl_usd", "legendFormat": "PnL" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Reconciliation Status",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_reconciliation_passed", "legendFormat": "Passed" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PASSED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Drift Events",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_drift_events_active", "legendFormat": "Active Drifts" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "WS Health Score",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_ws_health_score", "legendFormat": "WS Health" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "PnL Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_total_pnl_usd", "legendFormat": "Total PnL" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Scan Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(openclaw_scan_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(openclaw_scan_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Reconciliation Results",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(openclaw_reconciliation_runs_total[5m])", "legendFormat": "Runs/min" },
        { "expr": "rate(openclaw_reconciliation_failures_total[5m])", "legendFormat": "Failures/min" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "EventStore Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(openclaw_event_store_appends_total[1m])", "legendFormat": "Events/sec" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage (MB)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS MB" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Active Threads",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_thread_count", "legendFormat": "Threads" }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Recent Critical Incidents",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "openclaw_critical_incidents_total", "legendFormat": "Incidents" }
      ]
    },
    {
      "id": 99,
      "type": "row",
      "title": "Phase 7 — Hardening Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 100,
      "type": "gauge",
      "title": "Balance Divergence",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 27 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_balance_divergence_pct",
          "legendFormat": "Divergence %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 101,
      "type": "timeseries",
      "title": "Balance EWMA Drift",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 27 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_balance_ewma_divergence_pct",
          "legendFormat": "EWMA Drift %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Replay Divergence Counter",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 27 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_replay_divergence_total",
          "legendFormat": "Divergences"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 103,
      "type": "text",
      "title": "Deployment Approval Status",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 27 },
      "options": {
        "mode": "markdown",
        "content": "## Approval Required for STABLE\n\nAll promotions from **CANARY** to **STABLE** require a valid Ed25519 operator signature.\n\n- Signature verified via `security/operator_approval.py`\n- Tampered or unknown-key records are **rejected** (fail-closed)\n- Audit trail written to `data/approval_audit.jsonl`\n\n> Use `security/operator_approval.py sign` to generate a valid approval record."
      }
    },
    {
      "id": 104,
      "type": "gauge",
      "title": "Replay Equivalence Score",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_replay_equivalent",
          "legendFormat": "Equivalent (1=OK, 0=Diverged)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DIVERGED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "EQUIVALENT", "color": "green" } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 105,
      "type": "table",
      "title": "Rollback Trigger Ladder",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 33 },
      "datasource": null,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "targets": [],
      "pluginVersion": "9.0.0",
      "type": "table",
      "description": "Static reference: rollback trigger types and their default cooldowns",
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "datasource": {
        "type": "grafana",
        "uid": "-- Mixed --"
      }
    },
    {
      "id": 106,
      "type": "timeseries",
      "title": "Live Survivability Trend",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "openclaw_survivability_score",
          "legendFormat": "Survivability Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 107,
      "type": "timeseries",
      "title": "Integrity Drift Trend",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 39 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(openclaw_integrity_critical_total[5m])",
          "legendFormat": "Critical Integrity Events/min"
        },
        {
          "expr": "openclaw_integrity_critical_total",
          "legendFormat": "Total Critical Integrity Events"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["openclaw", "trading", "crypto"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "UTC",
  "title": "OpenClaw Trading Bot",
  "uid": "openclaw-main",
  "version": 1
}
